# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3020

# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/nineclip?schema=public"

# Redis (Railway Redis)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Midtrans
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# Storage (local dev, swap to R2/S3 in prod)
STORAGE_PATH=./storage

# Google OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social Verification (v2-5) — opsional, fallback manual jika kosong/absen.
# YOUTUBE_API_KEY: YouTube Data API v3 → verifikasi bio YouTube otomatis.
# TikTok pakai Puppeteer (npm install puppeteer) — fallback manual jika belum ada.
YOUTUBE_API_KEY=
PUPPETEER_EXECUTABLE_PATH=
